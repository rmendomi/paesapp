  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./dist-seed",
    "rootDir": "."
  },
  "include": ["prisma/seed.ts"],
  "exclude": ["node_modules", "client", "server"]
}
